{
  "_version": 3,
  "type": "custom",
  "docker": {
    "ports": {
      "game": {
        "port": "8211",
        "multiplier": "1"
      },
      "rcon": {
        "port": "37015",
        "multiplier": "1"
      },
      "query": {
        "port": "27015",
        "multiplier": "1"
      }
    },
    "image": {
      "name": "ghcr.io/twistedbobross/gsa-compatible-palworld",
      "tag": "ltsc2022-cleanroom-v10"
    },
    "automatic_ports": true,
    "envs": {
      "PAL_DATA_DIR": "C:/serverfiles",
      "PAL_STEAMCMD_DIR": "C:/serverfiles/_steamcmd",
      "PAL_SERVER_ROOT": "C:/serverfiles/PalServer",
      "PAL_LOG_DIR": "C:/serverfiles/Logs",
      "PAL_BRIDGE_DIR": "C:/serverfiles/TKGBridge",
      "PAL_BRIDGE_TRACE": "{config_parameter id=\"bridge_trace\"}",
      "PAL_MODS_DIR": "C:/image-mods",
      "PAL_SERVER_NAME": "{gameserver.list_name}",
      "PAL_SERVER_DESCRIPTION": "{config_parameter id=\"server_description\"}",
      "PAL_SERVER_PASSWORD": "{config_parameter id=\"server_password\"}",
      "PAL_ADMIN_PASSWORD": "{gameserver.rcon_password}",
      "PAL_REGION": "{config_parameter id=\"region\"}",
      "PAL_GAME_PORT": "{gameserver.game_port}",
      "PAL_QUERY_PORT": "{gameserver.query_port}",
      "PAL_RCON_PORT": "{gameserver.rcon_port}",
      "PAL_PUBLIC_PORT": "{gameserver.game_port}",
      "PAL_PUBLIC_IP": "{config_parameter id=\"public_ip\"}",
      "PAL_PUBLIC_LOBBY": "{config_parameter id=\"public_lobby\"}",
      "PAL_REST_PORT": "8212",
      "PAL_MAX_PLAYERS": "{gameserver.slot_limit}",
      "PAL_UPDATE_ON_START": "{config_parameter id=\"update_on_start\"}",
      "PAL_VALIDATE_ON_UPDATE": "{config_parameter id=\"validate_on_update\"}",
      "PAL_ALLOW_CLIENT_MOD": "{config_parameter id=\"allow_client_mod\"}",
      "PAL_CROSSPLAY_PLATFORMS": "{config_parameter id=\"crossplay_platforms\"}",
      "PAL_PVP_ENABLED": "{config_parameter id=\"pvp_enabled\"}",
      "PAL_DEATH_PENALTY": "{config_parameter id=\"death_penalty\"}",
      "PAL_INVADER_ENABLED": "{config_parameter id=\"invader_enabled\"}",
      "PAL_FAST_TRAVEL_ENABLED": "{config_parameter id=\"fast_travel_enabled\"}",
      "PAL_EXP_RATE": "{config_parameter id=\"exp_rate\"}",
      "PAL_CAPTURE_RATE": "{config_parameter id=\"capture_rate\"}",
      "PAL_SPAWN_RATE": "{config_parameter id=\"spawn_rate\"}",
      "PAL_DAY_TIME_SPEED_RATE": "{config_parameter id=\"day_time_speed_rate\"}",
      "PAL_NIGHT_TIME_SPEED_RATE": "{config_parameter id=\"night_time_speed_rate\"}",
      "PAL_EGG_HATCHING_TIME": "{config_parameter id=\"egg_hatching_time\"}",
      "PAL_EXTRA_ARGS": "{config_parameter id=\"extra_args\"}"
    },
    "mounts": {
      "{container.home_root}/serverfiles": "c:/serverfiles"
    }
  },
  "dir": {
    "Serverfiles": {
      "path": "\\serverfiles",
      "create": false,
      "type": "normal"
    },
    "Compatibility Logs": {
      "path": "\\serverfiles\\Logs",
      "create": true,
      "type": "logs"
    },
    "Bridge Logs": {
      "path": "\\serverfiles\\TKGBridge",
      "create": true,
      "type": "logs"
    },
    "Palworld Native Logs": {
      "path": "\\serverfiles\\PalServer\\Pal\\Saved\\Logs",
      "create": false,
      "type": "logs"
    }
  },
  "game": {
    "server": {
      "wipe": [
        "\\serverfiles\\PalServer\\Pal\\Saved\\SaveGames"
      ],
      "backup": {
        "Palworld Saved": "\\serverfiles\\PalServer\\Pal\\Saved",
        "TKGBridge State": "\\serverfiles\\TKGBridge"
      },
      "command_control": {
        "type": "rest_local",
        "commands": {
          "save": "{\"url\":\"http://localhost:8212/v1/api/save\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"\"}",
          "broadcast": "{\"url\":\"http://localhost:8212/v1/api/announce\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"message\\\": \\\"{message}\\\"}\"}",
          "kick": "{\"url\":\"http://localhost:8212/v1/api/kick\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\",\\\"message\\\": \\\"{reason}\\\"}\"}",
          "ban": "{\"url\":\"http://localhost:8212/v1/api/ban\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\",\\\"message\\\": \\\"{reason}\\\"}\"}",
          "unban": "{\"url\":\"http://localhost:8212/v1/api/unban\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\"}\"}"
        }
      },
      "monitoring": {
        "type": "container",
        "recovery_mode": true
      }
    },
    "type": "custom",
    "config": {
      "files": {
        "PalWorldSettings.ini": {
          "path": "\\serverfiles\\PalServer\\Pal\\Saved\\Config\\WindowsServer\\PalWorldSettings.ini",
          "info": "You can edit this file directly for advanced settings. The launcher refreshes the common startup, server-list, and Gameplay Settings values below on boot.",
          "disable_edit": "0",
          "content": "[/Script/Pal.PalGameWorldSettings]\r\nOptionSettings=(ServerName=\"{gameserver.list_name}\",ServerDescription=\"{config_parameter id=\"server_description\"}\",ServerPassword=\"{config_parameter id=\"server_password\"}\",AdminPassword=\"{gameserver.rcon_password}\",ServerPlayerMaxNum={gameserver.slot_limit},Region=\"{config_parameter id=\"region\"}\",PublicIP=\"{config_parameter id=\"public_ip\"}\",PublicPort={gameserver.game_port},QueryPort={gameserver.query_port},RCONEnabled=True,RCONPort={gameserver.rcon_port},RESTAPIEnabled=True,RESTAPIPort=8212,LogFormatType=Text,bAllowClientMod={config_parameter id=\"allow_client_mod\"},CrossplayPlatforms={config_parameter id=\"crossplay_platforms\"},bIsPvP={config_parameter id=\"pvp_enabled\"},bEnablePlayerToPlayerDamage={config_parameter id=\"pvp_enabled\"},bEnableDefenseOtherGuildPlayer={config_parameter id=\"pvp_enabled\"},DeathPenalty={config_parameter id=\"death_penalty\"},bEnableInvaderEnemy={config_parameter id=\"invader_enabled\"},bEnableFastTravel={config_parameter id=\"fast_travel_enabled\"},ExpRate={config_parameter id=\"exp_rate\"},PalCaptureRate={config_parameter id=\"capture_rate\"},PalSpawnNumRate={config_parameter id=\"spawn_rate\"},DayTimeSpeedRate={config_parameter id=\"day_time_speed_rate\"},NightTimeSpeedRate={config_parameter id=\"night_time_speed_rate\"},PalEggDefaultHatchingTime={config_parameter id=\"egg_hatching_time\"})"
        }
      },
      "parameters": {
        "server_description": {
          "name": "Server Description",
          "info": "Description shown in the Palworld server list.",
          "section": "Server",
          "type": "text",
          "content": "Palworld server hosted with GameServerApp"
        },
        "server_password": {
          "name": "Server Password",
          "info": "Optional join password.",
          "section": "Access",
          "type": "text",
          "content": ""
        },
        "public_ip": {
          "name": "Public IP",
          "info": "Optional public IPv4 address override.",
          "section": "Server",
          "type": "text",
          "content": ""
        },
        "public_lobby": {
          "name": "Community/Public Lobby",
          "info": "Adds -publiclobby so the server can appear in the community server list.",
          "section": "Server",
          "type": "boolean",
          "content": "1"
        },
        "region": {
          "name": "Server Region",
          "info": "Optional community-list region label written into PalWorldSettings.ini.",
          "section": "Server",
          "type": "text",
          "content": ""
        },
        "update_on_start": {
          "name": "Update On Start",
          "info": "Runs SteamCMD update when the container starts.",
          "section": "Install",
          "type": "boolean",
          "content": "1"
        },
        "validate_on_update": {
          "name": "Validate On Update",
          "info": "Adds Steam validation during update. Slower but useful for repair.",
          "section": "Install",
          "type": "boolean",
          "content": "0"
        },
        "bridge_trace": {
          "name": "TKG Trace Mode",
          "info": "Writes deeper TKGBridge hook and player-state diagnostics to TKGBridge\\trace.log.",
          "section": "Advanced",
          "type": "boolean",
          "content": "0"
        },
        "allow_client_mod": {
          "name": "Allow Modded Clients",
          "info": "Permits players with client mods to connect.",
          "section": "Access",
          "type": "boolean",
          "content": "0"
        },
        "crossplay_platforms": {
          "name": "Allowed Platforms",
          "info": "Controls which client platforms may join.",
          "section": "Access",
          "type": "array",
          "dropdown": "{\"All Platforms\":\"(Steam,Xbox,PS5,Mac)\",\"Steam Only\":\"(Steam)\",\"Steam + Xbox\":\"(Steam,Xbox)\",\"Steam + Xbox + PS5\":\"(Steam,Xbox,PS5)\"}"
        },
        "pvp_enabled": {
          "name": "Enable PvP",
          "info": "Turns on Palworld's PvP-related damage flags together.",
          "section": "Gameplay Settings",
          "type": "boolean",
          "content": "0"
        },
        "death_penalty": {
          "name": "Death Penalty",
          "info": "Controls what players drop on death.",
          "section": "Gameplay Settings",
          "type": "array",
          "dropdown": "{\"All Items + Equipment + Team Pals\":\"All\",\"Items + Equipment\":\"ItemAndEquipment\",\"Items Only\":\"Item\",\"None\":\"None\"}"
        },
        "invader_enabled": {
          "name": "Enable Base Raids",
          "info": "Allows NPC raid events against player bases.",
          "section": "Gameplay Settings",
          "type": "boolean",
          "content": "1"
        },
        "fast_travel_enabled": {
          "name": "Enable Fast Travel",
          "info": "Controls whether players can fast travel.",
          "section": "Gameplay Settings",
          "type": "boolean",
          "content": "1"
        },
        "exp_rate": {
          "name": "Experience Rate",
          "info": "Experience gain multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "capture_rate": {
          "name": "Pal Capture Rate",
          "info": "Pal capture chance multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "spawn_rate": {
          "name": "Pal Spawn Rate",
          "info": "Wild Pal spawn multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "day_time_speed_rate": {
          "name": "Daytime Speed",
          "info": "How quickly daytime passes.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "night_time_speed_rate": {
          "name": "Nighttime Speed",
          "info": "How quickly nighttime passes.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "egg_hatching_time": {
          "name": "Huge Egg Incubation Hours",
          "info": "Base hours required to hatch a huge egg.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "72.0"
        },
        "extra_args": {
          "name": "Extra Launch Arguments",
          "info": "Additional command-line arguments appended to the server launch.",
          "section": "Advanced",
          "type": "text",
          "content": ""
        }
      }
    }
  }
}
