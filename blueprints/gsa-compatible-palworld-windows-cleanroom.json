{
  "_version": 3,
  "blueprint": {
    "version": "1.2.4",
    "name": "GSA-Compatible Palworld",
    "app_id": 17,
    "os": "Windows"
  },
  "docker": {
    "ports": {
      "query": {
        "port": "27015",
        "multiplier": "1"
      },
      "rcon": {
        "port": "37015",
        "multiplier": "1"
      },
      "game": {
        "port": "7777",
        "multiplier": "2"
      },
      "raw": {
        "port": "7778",
        "multiplier": "2"
      }
    },
    "image": {
      "name": "ghcr.io/twistedbobross/gsa-compatible-palworld",
      "tag": "ltsc2022-cleanroom-v16"
    },
    "automatic_ports": true,
    "envs": {
      "PAL_GSA_STEAM_MODE": "true",
      "PAL_DATA_DIR": "C:/Users/ContainerUser/serverfiles",
      "PAL_STEAMCMD_DIR": "C:/Users/ContainerUser/serverfiles/_steamcmd",
      "PAL_SERVER_ROOT": "C:/Users/ContainerUser/serverfiles",
      "PAL_LOG_DIR": "C:/Users/ContainerUser/serverfiles/logs",
      "PAL_BRIDGE_DIR": "C:/Users/ContainerUser/serverfiles/TKGBridge",
      "PAL_BRIDGE_TRACE": "{config_parameter id=\"bridge_trace\"}",
      "PAL_MODS_DIR": "C:/image-mods",
      "PAL_SERVER_NAME": "{gameserver.list_name}",
      "PAL_SERVER_DESCRIPTION": "{config_parameter id=\"server_description\"}",
      "PAL_SERVER_PASSWORD": "{config_parameter id=\"server_password\"}",
      "PAL_ADMIN_PASSWORD": "{gameserver.rcon_password}",
      "PAL_REGION": "{config_parameter id=\"region\"}",
      "PAL_GAME_PORT": "{gameserver.game_port}",
      "PAL_QUERY_PORT": "{gameserver.query_port}",
      "PAL_RCON_PORT": "{gameserver.rcon_port}",
      "PAL_PUBLIC_PORT": "{gameserver.game_port}",
      "PAL_PUBLIC_IP": "{config_parameter id=\"public_ip\"}",
      "PAL_PUBLIC_LOBBY": "{config_parameter id=\"public_lobby\"}",
      "PAL_REST_PORT": "8080",
      "PAL_MAX_PLAYERS": "{gameserver.slot_limit}",
      "PAL_UPDATE_ON_START": "{config_parameter id=\"update_on_start\"}",
      "PAL_VALIDATE_ON_UPDATE": "{config_parameter id=\"validate_on_update\"}",
      "PAL_ALLOW_CLIENT_MOD": "{config_parameter id=\"allow_client_mod\"}",
      "PAL_CROSSPLAY_PLATFORMS": "{config_parameter id=\"crossplay_platforms\"}",
      "PAL_PVP_ENABLED": "{config_parameter id=\"pvp_enabled\"}",
      "PAL_DEATH_PENALTY": "{config_parameter id=\"death_penalty\"}",
      "PAL_INVADER_ENABLED": "{config_parameter id=\"invader_enabled\"}",
      "PAL_FAST_TRAVEL_ENABLED": "{config_parameter id=\"fast_travel_enabled\"}",
      "PAL_EXP_RATE": "{config_parameter id=\"exp_rate\"}",
      "PAL_CAPTURE_RATE": "{config_parameter id=\"capture_rate\"}",
      "PAL_SPAWN_RATE": "{config_parameter id=\"spawn_rate\"}",
      "PAL_DAY_TIME_SPEED_RATE": "{config_parameter id=\"day_time_speed_rate\"}",
      "PAL_NIGHT_TIME_SPEED_RATE": "{config_parameter id=\"night_time_speed_rate\"}",
      "PAL_EGG_HATCHING_TIME": "{config_parameter id=\"egg_hatching_time\"}",
      "PAL_EXTRA_ARGS": "{config_parameter id=\"extra_args\"}"
    },
    "mounts": {
      "{host.container_root}\\serverfiles": "C:\\Users\\ContainerUser\\serverfiles"
    }
  },
  "dir": {
    "Saves": {
      "path": "/serverfiles/Pal/Saved/SaveGames",
      "create": false,
      "type": "saves"
    },
    "Logs": {
      "path": "/serverfiles/logs",
      "create": true,
      "type": "logs"
    },
    "Bridge Logs": {
      "path": "/serverfiles/TKGBridge",
      "create": true,
      "type": "logs"
    },
    "Palworld Native Logs": {
      "path": "/serverfiles/Pal/Saved/Logs",
      "create": false,
      "type": "logs"
    }
  },
  "game": {
    "server": {
      "wipe": [
        "/serverfiles/Pal/Saved/SaveGames"
      ],
      "backup": {
        "Palworld Saved": "/serverfiles/Pal/Saved",
        "TKGBridge State": "/serverfiles/TKGBridge"
      },
      "command_control": {
        "type": "rest_local",
        "commands": {
          "save": "{\"url\":\"http://localhost:8080/v1/api/save\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"\"}",
          "broadcast": "{\"url\":\"http://localhost:8080/v1/api/announce\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"message\\\": \\\"{message}\\\"}\"}",
          "kick": "{\"url\":\"http://localhost:8080/v1/api/kick\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\",\\\"message\\\": \\\"{reason}\\\"}\"}",
          "ban": "{\"url\":\"http://localhost:8080/v1/api/ban\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\",\\\"message\\\": \\\"{reason}\\\"}\"}",
          "unban": "{\"url\":\"http://localhost:8080/v1/api/unban\", \"method\": \"POST\", \"header\": \"-H 'Authorization: Basic {container.rest_basic_auth_admin_user}' -H 'Content-Type: application/json'\", \"body\": \"{\\\"userid\\\": \\\"{player.id}\\\"}\"}"
        }
      },
      "monitoring": {
        "type": "rcon",
        "recovery_mode": true
      }
    },
    "type": "gsa-steam",
    "steam": {
      "client_id": "1623730",
      "server_id": "2394010",
      "requires_steam_auth": false,
      "launch_parameters": "-NoLogo -ExecutionPolicy Bypass -File C:\\Start.ps1",
      "executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "executable_output_log": "C:\\Users\\ContainerUser\\serverfiles\\logs",
      "user": "containeruser"
    },
    "config": {
      "files": {
        "PalWorldSettings.ini": {
          "path": "/serverfiles/Pal/Saved/Config/WindowsServer/PalWorldSettings.ini",
          "info": "You can edit this file directly for advanced settings. The launcher refreshes the common startup, server-list, and Gameplay Settings values below on boot.",
          "disable_edit": "0",
          "content": "[/Script/Pal.PalGameWorldSettings]\r\nOptionSettings=(ServerName=\"{gameserver.list_name}\",ServerDescription=\"{config_parameter id=\"server_description\"}\",ServerPassword=\"{config_parameter id=\"server_password\"}\",AdminPassword=\"{gameserver.rcon_password}\",ServerPlayerMaxNum={gameserver.slot_limit},Region=\"{config_parameter id=\"region\"}\",PublicIP=\"{config_parameter id=\"public_ip\"}\",PublicPort={gameserver.game_port},QueryPort={gameserver.query_port},RCONEnabled=True,RCONPort={gameserver.rcon_port},RESTAPIEnabled=True,RESTAPIPort=8080,LogFormatType=\"Text\",bAllowClientMod={config_parameter id=\"allow_client_mod\"},CrossplayPlatforms={config_parameter id=\"crossplay_platforms\"},bIsPvP={config_parameter id=\"pvp_enabled\"},bEnablePlayerToPlayerDamage={config_parameter id=\"pvp_enabled\"},bEnableDefenseOtherGuildPlayer={config_parameter id=\"pvp_enabled\"},DeathPenalty={config_parameter id=\"death_penalty\"},bEnableInvaderEnemy={config_parameter id=\"invader_enabled\"},bEnableFastTravel={config_parameter id=\"fast_travel_enabled\"},PalEggDefaultHatchingTime={config_parameter id=\"egg_hatching_time\"},DayTimeSpeedRate={config_parameter id=\"day_time_speed_rate\"},NightTimeSpeedRate={config_parameter id=\"night_time_speed_rate\"},ExpRate={config_parameter id=\"exp_rate\"},PalCaptureRate={config_parameter id=\"capture_rate\"},PalSpawnNumRate={config_parameter id=\"spawn_rate\"},bUseAuth=True)"
        }
      },
      "parameters": {
        "server_description": {
          "name": "Server Description",
          "info": "Description shown in the Palworld server list.",
          "section": "Server",
          "type": "text",
          "content": "Palworld server hosted with GameServerApp"
        },
        "server_password": {
          "name": "Server Password",
          "info": "Optional join password.",
          "section": "Access",
          "type": "text",
          "content": ""
        },
        "public_ip": {
          "name": "Public IP",
          "info": "Optional public IPv4 address override.",
          "section": "Server",
          "type": "text",
          "content": ""
        },
        "public_lobby": {
          "name": "Community/Public Lobby",
          "info": "Use 1 to enable or 0 to disable -publiclobby so the server can appear in the community server list.",
          "section": "Server",
          "type": "text",
          "content": "1"
        },
        "region": {
          "name": "Server Region",
          "info": "Optional community-list region label written into PalWorldSettings.ini.",
          "section": "Server",
          "type": "text",
          "content": "NA"
        },
        "update_on_start": {
          "name": "Fallback Update On Start",
          "info": "Use 1 to enable or 0 to disable. Only used by the wrapper if GSA's Steam-managed install is missing or you want an extra in-container update pass.",
          "section": "Install",
          "type": "text",
          "content": "0"
        },
        "validate_on_update": {
          "name": "Validate On Update",
          "info": "Use 1 to enable or 0 to disable Steam validation during fallback update. Slower but useful for repair.",
          "section": "Install",
          "type": "text",
          "content": "0"
        },
        "bridge_trace": {
          "name": "TKG Trace Mode",
          "info": "Use 1 to enable or 0 to disable deeper TKGBridge hook and player-state diagnostics in TKGBridge\\trace.log.",
          "section": "Advanced",
          "type": "text",
          "content": "0"
        },
        "allow_client_mod": {
          "name": "Allow Modded Clients",
          "info": "Use 1 to allow modded clients or 0 to keep them blocked.",
          "section": "Access",
          "type": "text",
          "content": "0"
        },
        "crossplay_platforms": {
          "name": "Allowed Platforms",
          "info": "Enter the raw Palworld tuple, for example (Steam,Xbox,PS5,Mac), (Steam), or (Steam,Xbox).",
          "section": "Access",
          "type": "text",
          "content": "(\"Steam\",\"Xbox\",\"PS5\",\"Mac\")"
        },
        "pvp_enabled": {
          "name": "Enable PvP",
          "info": "Use 1 to enable or 0 to disable Palworld's PvP-related damage flags together.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "0"
        },
        "death_penalty": {
          "name": "Death Penalty",
          "info": "Valid values: All, ItemAndEquipment, Item, None.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "All"
        },
        "invader_enabled": {
          "name": "Enable Base Raids",
          "info": "Use 1 to enable or 0 to disable NPC raid events against player bases.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1"
        },
        "fast_travel_enabled": {
          "name": "Enable Fast Travel",
          "info": "Use 1 to enable or 0 to disable fast travel.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1"
        },
        "exp_rate": {
          "name": "Experience Rate",
          "info": "Experience gain multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "capture_rate": {
          "name": "Pal Capture Rate",
          "info": "Pal capture chance multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "spawn_rate": {
          "name": "Pal Spawn Rate",
          "info": "Wild Pal spawn multiplier.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "day_time_speed_rate": {
          "name": "Daytime Speed",
          "info": "How quickly daytime passes.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "night_time_speed_rate": {
          "name": "Nighttime Speed",
          "info": "How quickly nighttime passes.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "1.0"
        },
        "egg_hatching_time": {
          "name": "Huge Egg Incubation Hours",
          "info": "Base hours required to hatch a huge egg.",
          "section": "Gameplay Settings",
          "type": "text",
          "content": "72.0"
        },
        "extra_args": {
          "name": "Extra Launch Arguments",
          "info": "Additional command-line arguments appended by the wrapper before the Palworld server is launched.",
          "section": "Advanced",
          "type": "text",
          "content": ""
        }
      }
    }
  }
}
