{
  "_version": 3,
  "type": "custom",
  "docker": {
    "ports": {
      "game": {
        "port": "8211",
        "multiplier": "1"
      },
      "query": {
        "port": "27015",
        "multiplier": "1"
      }
    },
    "image": {
      "name": "ghcr.io/twistedbobross/gsa-compatible-palworld",
      "tag": "ltsc2022-cleanroom-v8"
    },
    "automatic_ports": true,
    "envs": {
      "PAL_DATA_DIR": "C:/serverfiles",
      "PAL_STEAMCMD_DIR": "C:/serverfiles/_steamcmd",
      "PAL_SERVER_ROOT": "C:/serverfiles/PalServer",
      "PAL_LOG_DIR": "C:/serverfiles/Logs",
      "PAL_BRIDGE_DIR": "C:/serverfiles/TKGBridge",
      "PAL_MODS_DIR": "C:/image-mods",
      "PAL_SERVER_NAME": "{gameserver.list_name}",
      "PAL_SERVER_DESCRIPTION": "{config_parameter id=\"server_description\"}",
      "PAL_SERVER_PASSWORD": "{config_parameter id=\"server_password\"}",
      "PAL_ADMIN_PASSWORD": "{config_parameter id=\"admin_password\"}",
      "PAL_REGION": "{config_parameter id=\"region\"}",
      "PAL_GAME_PORT": "{gameserver.game_port}",
      "PAL_QUERY_PORT": "{gameserver.query_port}",
      "PAL_PUBLIC_PORT": "{gameserver.game_port}",
      "PAL_PUBLIC_IP": "{config_parameter id=\"public_ip\"}",
      "PAL_PUBLIC_LOBBY": "{config_parameter id=\"public_lobby\"}",
      "PAL_REST_PORT": "8212",
      "PAL_MAX_PLAYERS": "{gameserver.slot_limit}",
      "PAL_UPDATE_ON_START": "{config_parameter id=\"update_on_start\"}",
      "PAL_VALIDATE_ON_UPDATE": "{config_parameter id=\"validate_on_update\"}",
      "PAL_ALLOW_CLIENT_MOD": "{config_parameter id=\"allow_client_mod\"}",
      "PAL_CROSSPLAY_PLATFORMS": "{config_parameter id=\"crossplay_platforms\"}",
      "PAL_EXTRA_ARGS": "{config_parameter id=\"extra_args\"}"
    },
    "mounts": {
      "{container.home_root}/serverfiles": "c:/serverfiles"
    }
  },
  "dir": {
    "Serverfiles": {
      "path": "\\serverfiles",
      "create": false,
      "type": "normal"
    },
    "Compatibility Logs": {
      "path": "\\serverfiles\\Logs",
      "create": true,
      "type": "logs"
    },
    "Bridge Logs": {
      "path": "\\serverfiles\\TKGBridge",
      "create": true,
      "type": "logs"
    },
    "Palworld Native Logs": {
      "path": "\\serverfiles\\PalServer\\Pal\\Saved\\Logs",
      "create": false,
      "type": "logs"
    }
  },
  "game": {
    "server": {
      "wipe": [
        "\\serverfiles\\PalServer\\Pal\\Saved\\SaveGames"
      ],
      "backup": {
        "Palworld Saved": "\\serverfiles\\PalServer\\Pal\\Saved",
        "TKGBridge State": "\\serverfiles\\TKGBridge"
      },
      "monitoring": {
        "type": "container",
        "recovery_mode": true
      }
    },
    "type": "custom",
    "config": {
      "files": {
        "PalWorldSettings.ini": {
          "path": "\\serverfiles\\PalServer\\Pal\\Saved\\Config\\WindowsServer\\PalWorldSettings.ini",
          "info": "You can edit this file directly for advanced settings. The launcher only refreshes the common startup and server-list fields below on boot.",
          "disable_edit": "0",
          "content": "[/Script/Pal.PalGameWorldSettings]\r\nOptionSettings=(ServerName=\"{gameserver.list_name}\",ServerDescription=\"{config_parameter id=\"server_description\"}\",ServerPassword=\"{config_parameter id=\"server_password\"}\",AdminPassword=\"{config_parameter id=\"admin_password\"}\",ServerPlayerMaxNum={gameserver.slot_limit},Region=\"{config_parameter id=\"region\"}\",PublicIP=\"{config_parameter id=\"public_ip\"}\",PublicPort={gameserver.game_port},QueryPort={gameserver.query_port},RCONEnabled=False,RESTAPIEnabled=True,RESTAPIPort=8212,LogFormatType=Text,bAllowClientMod={config_parameter id=\"allow_client_mod\"},CrossplayPlatforms={config_parameter id=\"crossplay_platforms\"})"
        }
      },
      "parameters": {
        "server_description": {
          "name": "Server Description",
          "info": "Description shown in the Palworld server list.",
          "section": "Server",
          "type": "text",
          "content": "Palworld server hosted with GameServerApp"
        },
        "server_password": {
          "name": "Server Password",
          "info": "Optional join password.",
          "section": "Access",
          "type": "text",
          "content": ""
        },
        "admin_password": {
          "name": "Admin Password",
          "info": "Reserved for future first-party control surfaces and in-server admin authentication.",
          "section": "Access",
          "type": "text",
          "content": ""
        },
        "public_ip": {
          "name": "Public IP",
          "info": "Optional public IPv4 address override.",
          "section": "Server",
          "type": "text",
          "content": ""
        },
        "public_lobby": {
          "name": "Community/Public Lobby",
          "info": "Adds -publiclobby so the server can appear in the community server list.",
          "section": "Server",
          "type": "boolean",
          "content": "1"
        },
        "region": {
          "name": "Server Region",
          "info": "Optional community-list region label written into PalWorldSettings.ini.",
          "section": "Server",
          "type": "text",
          "content": ""
        },
        "update_on_start": {
          "name": "Update On Start",
          "info": "Runs SteamCMD update when the container starts.",
          "section": "Install",
          "type": "boolean",
          "content": "1"
        },
        "validate_on_update": {
          "name": "Validate On Update",
          "info": "Adds Steam validation during update. Slower but useful for repair.",
          "section": "Install",
          "type": "boolean",
          "content": "0"
        },
        "allow_client_mod": {
          "name": "Allow Modded Clients",
          "info": "Permits players with client mods to connect.",
          "section": "Access",
          "type": "boolean",
          "content": "0"
        },
        "crossplay_platforms": {
          "name": "Allowed Platforms",
          "info": "Controls which client platforms may join.",
          "section": "Access",
          "type": "array",
          "dropdown": "{\"All Platforms\":\"(Steam,Xbox,PS5,Mac)\",\"Steam Only\":\"(Steam)\",\"Steam + Xbox\":\"(Steam,Xbox)\",\"Steam + Xbox + PS5\":\"(Steam,Xbox,PS5)\"}"
        },
        "extra_args": {
          "name": "Extra Launch Arguments",
          "info": "Additional command-line arguments appended to the server launch.",
          "section": "Advanced",
          "type": "text",
          "content": ""
        }
      }
    }
  }
}
